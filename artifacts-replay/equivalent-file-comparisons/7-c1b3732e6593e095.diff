+    private fun tryGetMethod(
+        clazz: Class<*>,
+        name: String,
+        vararg params: Class<*>,
+    ): Method? =
+        try {
+            clazz.getDeclaredMethod(name, *params).also { it.isAccessible = true }
+        } catch (_: NoSuchMethodException) {
